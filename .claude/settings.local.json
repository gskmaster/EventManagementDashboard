{
  "permissions": {
    "allow": [
      "Bash(npm install @googlemaps/js-api-loader @types/google.maps)",
      "Bash(docker ps --format \"{{.Names}}\")",
      "Bash(docker restart eventmanagementdashboard-firebase-1)",
      "Bash(docker exec eventmanagementdashboard-firebase-1 ls -la /app/emulator-data/firestore_export/)",
      "Bash(docker exec eventmanagementdashboard-firebase-1 sh -c \"ls -la /app/emulator-data/firestore_export/\")",
      "Bash(docker exec eventmanagementdashboard-firebase-1 sh -c \"cat /app/emulator-data/firestore_export/firestore_export.overall_export_metadata\")",
      "Bash(docker exec eventmanagementdashboard-firebase-1 sh -c \"cat /app/firestore.rules\")",
      "Bash(docker exec eventmanagementdashboard-firebase-1 sh -c \"ls /app/emulator-data/firestore_export/\")",
      "Bash(docker exec eventmanagementdashboard-firebase-1 sh -c \"cat /app/emulator-data/firebase-export-metadata.json\")",
      "Bash(docker exec eventmanagementdashboard-firebase-1 sh -c \"ls -la /app/emulator-data/auth_export/\")",
      "Bash(docker exec eventmanagementdashboard-firebase-1 sh -c \"cat /app/emulator-data/auth_export/accounts.json\")",
      "Bash(node scripts/seed-emulator.mjs)",
      "Bash(npm run emulator:save)",
      "Bash(npm run emulator:save -- --force)"
    ]
  }
}
