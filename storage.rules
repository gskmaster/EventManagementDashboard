rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Public Speaker Registration: KTP Uploads
    match /ktp/{imageId} {
      allow write: if request.resource.size < 5 * 1024 * 1024;
      allow read: if request.auth != null;
    }

    // Public Payment Registration: Receipt Uploads
    // Read is public so getDownloadURL works for unauthenticated participants
    match /receipts_public/{projectId}/{receiptId} {
      allow write: if request.resource.size < 5 * 1024 * 1024;
      allow read: if true;
    }

    // Public Payment Registration: NPWP Uploads
    match /npwp_public/{projectId}/{fileId} {
      allow write: if request.resource.size < 5 * 1024 * 1024;
      allow read: if true;
    }

    // Public Usher Registration: KTP Uploads
    // Read is public so getDownloadURL works for unauthenticated registrants
    match /ktp_ushers/{imageId} {
      allow write: if request.resource.size < 5 * 1024 * 1024;
      allow read: if true;
    }

    // Public LO Registration: KTP Uploads
    // Read is public so getDownloadURL works for unauthenticated registrants
    match /ktp_lo/{imageId} {
      allow write: if request.resource.size < 5 * 1024 * 1024;
      allow read: if true;
    }

    // New unified KTP Scan path for all public forms
    match /ktp_scans/{imageId} {
      allow write: if request.resource.size < 5 * 1024 * 1024;
      allow read: if true;
    }

    // Bukti Potong PPh 21 (Tax Admin uploads, authenticated read)
    match /bukti_potong/{projectId}/{fileId} {
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024;
      allow read: if request.auth != null;
    }

    // Kwitansi uploads (authenticated read/write)
    match /kwitansi/{projectId}/{fileId} {
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024;
      allow read: if request.auth != null;
    }

    // Event Report photo uploads (LO / Usher / Event Manager)
    match /event_report_photos/{projectId}/{fileId} {
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
      allow read: if request.auth != null;
    }

    // Default authenticated access for everything else
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
